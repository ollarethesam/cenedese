# Copy this file to .env and fill in your values.
#
# Local development: use the discrete DB_* vars below (DEBUG=True).
DB_NAME=cenedese_demo
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432
SECRET_KEY=replace-me-with-a-real-secret-key
DEBUG=True
EMAIL_PASSWORD=        # Gmail app password for invionotifichepartite@gmail.com
RECIPIENT=             # Notification recipient (use a test address in dev)

# Production (Render): set these instead of the DB_* vars above.
# DB_URL takes precedence over DB_NAME/DB_USER/... when present.
# DB_URL=postgresql://user:pass@host/dbname
# ALLOWED_HOSTS=cenedese.onrender.com   # space-separated if more than one
# DEBUG=False
